{
  "name": "champions-stories",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "start": "bun run server.ts",
    "seed": "bun run scripts/seed.ts",
    "deploy:convex": "convex deploy --env-file .env.production --cmd 'bun run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "deploy:convex:ci": "convex deploy --cmd 'bun run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "deploy:cf": "wrangler pages deploy app/dist --project-name champions-stories --branch main"
  },
  "dependencies": {
    "@platejs/basic-nodes": "^53.0.0",
    "@platejs/markdown": "^53.0.0",
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.37.0",
    "csv-parse": "^6.2.1",
    "hono": "^4.7.4",
    "lucide-react": "^0.487.0",
    "platejs": "^53.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.3",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.11",
    "wrangler": "^4.85.0"
  }
}
